# Runtime
NODE_ENV=production
PORT=3000
DB_PATH=./crm.db
TRUST_PROXY=1

# Auth
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_ISSUER=capitalcitycontractors-crm
JWT_AUDIENCE=capitalcitycontractors-crm-users
ACCESS_TOKEN_TTL=12h

# Privacy
VISIT_IP_HASH_SALT=replace-with-a-second-random-secret-at-least-32-characters-long

# CORS
CORS_ORIGINS=https://capitalcitycontractors.ca,https://www.capitalcitycontractors.ca,http://localhost:3000,http://127.0.0.1:3000

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Limits
API_RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
VISIT_RATE_LIMIT_MAX=120
JSON_BODY_LIMIT=100kb
